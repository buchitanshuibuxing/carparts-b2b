#!/bin/bash
# CarParts B2B 管理工具
# 版本: 1.0.0

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 项目路径
CARPARTS_DIR="/opt/carparts"
BACKEND_DIR="$CARPARTS_DIR/backend"
BACKUP_DIR="$CARPARTS_DIR/backups"

# 显示标题
show_header() {
    clear
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}  CarParts B2B 管理面板${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo ""
}

# 显示菜单
show_menu() {
    echo -e "${GREEN}  1. 启动服务${NC}"
    echo -e "${GREEN}  2. 停止服务${NC}"
    echo -e "${GREEN}  3. 重启服务${NC}"
    echo -e "${GREEN}  4. 查看状态${NC}"
    echo -e "${GREEN}  5. 查看日志${NC}"
    echo -e "${YELLOW}  6. 备份数据库${NC}"
    echo -e "${YELLOW}  7. 恢复数据库${NC}"
    echo -e "${YELLOW}  8. 修改管理员密码${NC}"
    echo -e "${YELLOW}  9. 修改域名${NC}"
    echo -e "${YELLOW} 10. 更新系统${NC}"
    echo -e "${RED} 11. 卸载系统${NC}"
    echo -e "${BLUE} 12. 查看系统信息${NC}"
    echo -e "${BLUE} 13. 申请/续期SSL证书${NC}"
    echo -e "${RED}  0. 退出${NC}"
    echo ""
    echo -e "${CYAN}========================================${NC}"
}

# 启动服务
start_services() {
    echo -e "\n${YELLOW}正在启动服务...${NC}\n"

    sudo systemctl start postgresql 2>/dev/null
    echo -e "${GREEN}✓ PostgreSQL 已启动${NC}"

    cd "$BACKEND_DIR"
    pm2 restart carparts-api 2>/dev/null || pm2 start ecosystem.config.js
    echo -e "${GREEN}✓ 后端服务已启动${NC}"

    sudo systemctl restart nginx
    echo -e "${GREEN}✓ Nginx 已启动${NC}"

    echo -e "\n${GREEN}所有服务已启动！${NC}"
}

# 停止服务
stop_services() {
    echo -e "\n${YELLOW}正在停止服务...${NC}\n"

    pm2 stop carparts-api 2>/dev/null
    echo -e "${GREEN}✓ 后端服务已停止${NC}"

    sudo systemctl stop nginx
    echo -e "${GREEN}✓ Nginx 已停止${NC}"

    echo -e "\n${GREEN}所有服务已停止！${NC}"
}

# 重启服务
restart_services() {
    echo -e "\n${YELLOW}正在重启服务...${NC}\n"

    cd "$BACKEND_DIR"
    pm2 restart carparts-api
    echo -e "${GREEN}✓ 后端服务已重启${NC}"

    sudo systemctl restart nginx
    echo -e "${GREEN}✓ Nginx 已重启${NC}"

    echo -e "\n${GREEN}所有服务已重启！${NC}"
}

# 查看状态
show_status() {
    echo -e "\n${CYAN}========================================${NC}"
    echo -e "${CYAN}  服务状态${NC}"
    echo -e "${CYAN}========================================${NC}\n"

    if pg_isready &>/dev/null; then
        echo -e "${GREEN}● PostgreSQL: 运行中${NC}"
    else
        echo -e "${RED}● PostgreSQL: 未运行${NC}"
    fi

    if pgrep -x "nginx" &>/dev/null; then
        echo -e "${GREEN}● Nginx: 运行中${NC}"
    else
        echo -e "${RED}● Nginx: 未运行${NC}"
    fi

    echo ""
    pm2 status carparts-api 2>/dev/null || echo -e "${RED}● 后端API: 未运行${NC}"

    echo -e "\n${CYAN}系统资源:${NC}"
    echo -e "CPU: $(top -bn1 | grep "Cpu(s)" | awk '{print $2}')%"
    echo -e "内存: $(free -h | awk '/Mem:/ {print $3 "/" $2}')"
    echo -e "磁盘: $(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')"

    echo -e "\n${CYAN}========================================${NC}"
}

# 查看日志
show_logs() {
    echo -e "\n${YELLOW}选择日志类型:${NC}"
    echo "1. 实时日志"
    echo "2. 错误日志"
    echo "3. 最近日志(50行)"
    echo "4. 返回主菜单"
    echo ""
    read -p "请选择 [1-4]: " log_choice

    case $log_choice in
        1) pm2 logs carparts-api ;;
        2) pm2 logs carparts-api --err --lines 50 ;;
        3) pm2 logs carparts-api --lines 50 --nostream ;;
        4) return ;;
    esac
}

# 备份数据库
backup_database() {
    echo -e "\n${YELLOW}正在备份数据库...${NC}\n"

    mkdir -p "$BACKUP_DIR"
    source "$BACKEND_DIR/.env" 2>/dev/null

    BACKUP_FILE="$BACKUP_DIR/carparts_$(date +%Y%m%d_%H%M%S).sql.gz"
    PGPASSWORD="${DB_PASSWORD}" pg_dump -h localhost -U "${DB_USER}" -d "${DB_NAME}" | gzip > "$BACKUP_FILE"

    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✓ 备份完成！${NC}"
        echo -e "文件: $BACKUP_FILE"
        echo -e "大小: $(du -h "$BACKUP_FILE" | cut -f1)"
    else
        echo -e "${RED}✗ 备份失败！${NC}"
    fi

    echo -e "\n${CYAN}最近备份:${NC}"
    ls -lh "$BACKUP_DIR"/carparts_*.sql.gz 2>/dev/null | tail -5
}

# 恢复数据库
restore_database() {
    echo -e "\n${YELLOW}可用的备份文件:${NC}\n"

    backups=($(ls -t "$BACKUP_DIR"/carparts_*.sql.gz 2>/dev/null))

    if [ ${#backups[@]} -eq 0 ]; then
        echo -e "${RED}没有找到备份文件！${NC}"
        return
    fi

    for i in "${!backups[@]}"; do
        echo "$((i+1)). $(basename ${backups[$i]}) ($(du -h ${backups[$i]} | cut -f1))"
    done

    echo ""
    read -p "请选择备份文件编号 [1-${#backups[@]}]: " backup_choice

    if [ "$backup_choice" -lt 1 ] || [ "$backup_choice" -gt "${#backups[@]}" ]; then
        echo -e "${RED}无效的选择！${NC}"
        return
    fi

    SELECTED_BACKUP="${backups[$((backup_choice-1))]}"

    echo -e "\n${RED}警告: 恢复数据库将覆盖当前数据！${NC}"
    read -p "确认恢复？(y/n): " confirm

    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo -e "${YELLOW}已取消${NC}"
        return
    fi

    echo -e "\n${YELLOW}正在恢复...${NC}\n"
    source "$BACKEND_DIR/.env" 2>/dev/null
    gunzip -c "$SELECTED_BACKUP" | PGPASSWORD="${DB_PASSWORD}" psql -h localhost -U "${DB_USER}" -d "${DB_NAME}"

    echo -e "\n${GREEN}✓ 恢复完成！${NC}"
}

# 修改密码
change_password() {
    echo -e "\n${YELLOW}修改管理员密码${NC}\n"

    read -s -p "请输入新密码: " new_password
    echo ""
    read -s -p "请确认新密码: " confirm_password
    echo ""

    if [ "$new_password" != "$confirm_password" ]; then
        echo -e "${RED}两次密码不一致！${NC}"
        return
    fi

    if [ ${#new_password} -lt 6 ]; then
        echo -e "${RED}密码长度不能少于6位！${NC}"
        return
    fi

    source "$BACKEND_DIR/.env" 2>/dev/null
    HASH=$(cd "$BACKEND_DIR" && node -e "const bcrypt = require('bcrypt'); console.log(bcrypt.hashSync('$new_password', 10))")
    PGPASSWORD="${DB_PASSWORD}" psql -h localhost -U "${DB_USER}" -d "${DB_NAME}" -c "UPDATE users SET password_hash = '$HASH' WHERE username = 'admin';"

    echo -e "\n${GREEN}✓ 密码已修改！${NC}"
}

# 修改域名
change_domain() {
    echo -e "\n${YELLOW}修改域名${NC}\n"

    CURRENT_DOMAIN=$(grep "server_name" /etc/nginx/sites-available/carparts 2>/dev/null | head -1 | awk '{print $2}' | tr -d ';')
    echo -e "当前域名: ${CYAN}$CURRENT_DOMAIN${NC}\n"

    read -p "请输入新域名 (留空取消): " new_domain

    if [ -z "$new_domain" ]; then
        echo -e "${YELLOW}已取消${NC}"
        return
    fi

    sudo sed -i "s/server_name .*/server_name $new_domain;/" /etc/nginx/sites-available/carparts
    sudo sed -i "s/ALLOWED_ORIGINS=.*/ALLOWED_ORIGINS=https:\/\/$new_domain/" "$BACKEND_DIR/.env"

    sudo nginx -t && sudo systemctl restart nginx
    cd "$BACKEND_DIR" && pm2 restart carparts-api

    echo -e "\n${GREEN}✓ 域名已修改为: $new_domain${NC}"
}

# 更新系统
update_system() {
    echo -e "\n${YELLOW}正在更新...${NC}\n"

    cd "$CARPARTS_DIR"

    git pull origin main

    cd "$BACKEND_DIR"
    npm install --production
    npm run build

    cd "$CARPARTS_DIR/frontend"
    npm install
    npm run build

    cd "$BACKEND_DIR"
    pm2 restart carparts-api

    echo -e "\n${GREEN}✓ 更新完成！${NC}"
}

# 卸载系统
uninstall_system() {
    echo -e "\n${RED}========================================${NC}"
    echo -e "${RED}  警告: 卸载将删除所有数据！${NC}"
    echo -e "${RED}========================================${NC}\n"

    read -p "是否保留数据库备份？(y/n): " keep_backup
    read -p "确认卸载？(y/n): " confirm

    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo -e "${YELLOW}已取消${NC}"
        return
    fi

    echo -e "\n${YELLOW}正在卸载...${NC}\n"

    pm2 stop carparts-api 2>/dev/null
    pm2 delete carparts-api 2>/dev/null

    if [ "$keep_backup" = "y" ] || [ "$keep_backup" = "Y" ]; then
        mkdir -p /tmp/carparts_backup
        source "$BACKEND_DIR/.env" 2>/dev/null
        PGPASSWORD="${DB_PASSWORD}" pg_dump -h localhost -U "${DB_USER}" -d "${DB_NAME}" > /tmp/carparts_backup/carparts_final.sql
        echo -e "${GREEN}✓ 数据库已备份到: /tmp/carparts_backup/${NC}"
    fi

    sudo rm -f /etc/nginx/sites-enabled/carparts
    sudo rm -f /etc/nginx/sites-available/carparts
    sudo systemctl restart nginx

    sudo rm -rf "$CARPARTS_DIR"
    sudo rm -f /usr/local/bin/carparts

    echo -e "\n${GREEN}✓ 卸载完成！${NC}"
}

# 查看系统信息
show_info() {
    source "$BACKEND_DIR/.env" 2>/dev/null

    echo -e "\n${CYAN}========================================${NC}"
    echo -e "${CYAN}  系统信息${NC}"
    echo -e "${CYAN}========================================${NC}\n"

    cd "$CARPARTS_DIR"
    VERSION=$(git describe --tags --abbrev=0 2>/dev/null || echo "v1.0.0")
    echo -e "版本: ${GREEN}$VERSION${NC}"
    echo -e "安装目录: ${CYAN}$CARPARTS_DIR${NC}"

    DOMAIN=$(grep "server_name" /etc/nginx/sites-available/carparts 2>/dev/null | head -1 | awk '{print $2}' | tr -d ';')
    echo -e "域名: ${CYAN}$DOMAIN${NC}"

    echo -e "\n${CYAN}数据统计:${NC}"
    PARTS=$(PGPASSWORD="${DB_PASSWORD}" psql -h localhost -U "${DB_USER}" -d "${DB_NAME}" -t -c "SELECT COUNT(*) FROM parts;" 2>/dev/null | tr -d ' ')
    CUSTOMERS=$(PGPASSWORD="${DB_PASSWORD}" psql -h localhost -U "${DB_USER}" -d "${DB_NAME}" -t -c "SELECT COUNT(*) FROM customers;" 2>/dev/null | tr -d ' ')
    ORDERS=$(PGPASSWORD="${DB_PASSWORD}" psql -h localhost -U "${DB_USER}" -d "${DB_NAME}" -t -c "SELECT COUNT(*) FROM orders;" 2>/dev/null | tr -d ' ')

    echo -e "配件: ${GREEN}${PARTS:-0}${NC}"
    echo -e "客户: ${GREEN}${CUSTOMERS:-0}${NC}"
    echo -e "订单: ${GREEN}${ORDERS:-0}${NC}"

    echo -e "\n${CYAN}========================================${NC}"
}

# SSL证书管理
manage_ssl() {
    DOMAIN=$(grep "server_name" /etc/nginx/sites-available/carparts 2>/dev/null | head -1 | awk '{print $2}' | tr -d ';')

    if [ -z "$DOMAIN" ] || [[ "$DOMAIN" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo -e "${RED}需要配置域名才能申请SSL证书！${NC}"
        return
    fi

    echo -e "\n${YELLOW}正在申请/续期SSL证书...${NC}\n"
    sudo certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos --email "admin@$DOMAIN"
    echo -e "\n${GREEN}✓ SSL证书配置完成！${NC}"
}

# 主循环
main() {
    if [ ! -d "$CARPARTS_DIR" ]; then
        echo -e "${RED}CarParts B2B 未安装！${NC}"
        exit 1
    fi

    while true; do
        show_header
        show_menu

        read -p "请输入命令编号 [0-13]: " choice

        case $choice in
            1) start_services ;;
            2) stop_services ;;
            3) restart_services ;;
            4) show_status ;;
            5) show_logs ;;
            6) backup_database ;;
            7) restore_database ;;
            8) change_password ;;
            9) change_domain ;;
            10) update_system ;;
            11) uninstall_system ;;
            12) show_info ;;
            13) manage_ssl ;;
            0) echo -e "\n${GREEN}再见！${NC}\n"; exit 0 ;;
            *) echo -e "\n${RED}无效的选择！${NC}" ;;
        esac

        echo ""
        read -p "按 Enter 键继续..."
    done
}

main
