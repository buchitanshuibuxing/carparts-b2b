# Server
NODE_ENV=production
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=carparts
DB_PASSWORD=your-secure-password-here
DB_NAME=carparts

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DEST=/opt/carparts/uploads
MAX_FILE_SIZE=10485760

# AI Image Recognition (optional, at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Facebook App (optional)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
